<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="StudioNest Architects — BIM & Architectural Design firm crafting spaces that inspire.">
  <title><%= title || 'StudioNest Architects' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏛</text></svg>">
</head>
<body>

  <!-- NAVIGATION -->
  <nav class="nav" id="nav">
    <a href="/" class="nav-logo">Studio<span>Nest</span></a>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/projects">Projects</a>
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <% if (isAuthenticated) { %>
        <a href="/admin/dashboard" class="nav-admin-btn">Admin ↗</a>
      <% } else { %>
        <a href="/admin/login" class="nav-admin-btn">Admin</a>
      <% } %>
    </div>
    <button class="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- PAGE CONTENT -->
  <%- body %>

  <!-- BACK TO TOP -->
  <button id="back-to-top" style="position:fixed;bottom:2rem;right:2rem;width:42px;height:42px;background:var(--color-text);color:#fff;border:none;border-radius:50%;cursor:pointer;opacity:0;transition:opacity 0.3s;font-size:1.1rem;z-index:200;display:flex;align-items:center;justify-content:center;">↑</button>

  <!-- FOOTER -->
  <footer>
    <div class="footer-logo">StudioNest<span style="color:var(--color-accent)">.</span></div>
    <div class="footer-copy">© <%= new Date().getFullYear() %> StudioNest Architects. All rights reserved.</div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
