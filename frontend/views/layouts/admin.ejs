<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'StudioNest Admin' %></title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏛</text></svg>">
</head>
<body>

<% if (isAuthenticated) { %>
<!-- SIDEBAR -->
<aside class="admin-sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-text">StudioNest</div>
    <div class="sidebar-logo-sub">Admin Panel</div>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-nav-label">Main</div>
    <a href="/admin/dashboard" class="sidebar-nav-item">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>

    <div class="sidebar-nav-label">Content</div>
    <a href="/admin/projects" class="sidebar-nav-item">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
      Projects
    </a>
    <a href="/admin/blogs" class="sidebar-nav-item">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      Blog Posts
    </a>

    <div class="sidebar-nav-label">Site</div>
    <a href="/" target="_blank" class="sidebar-nav-item">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      View Website ↗
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-avatar"><%= (adminUsername || 'A').charAt(0).toUpperCase() %></div>
      <div class="sidebar-username"><%= adminUsername || 'Admin' %></div>
    </div>
    <form action="/admin/logout" method="POST">
      <button type="submit" class="sidebar-logout-btn">Sign Out</button>
    </form>
  </div>
</aside>

<!-- MAIN CONTENT -->
<main class="admin-main">
  <div class="admin-topbar">
    <div class="topbar-title"><%= title || 'Dashboard' %></div>
    <div class="topbar-actions">
      <a href="/admin/projects/new" class="btn btn-sm btn-primary">+ New Project</a>
      <a href="/admin/blogs/new" class="btn btn-sm btn-secondary">+ New Post</a>
    </div>
  </div>
  <div class="admin-content">
    <%- body %>
  </div>
</main>

<% } else { %>
  <%- body %>
<% } %>

<script src="/js/admin.js"></script>
</body>
</html>
