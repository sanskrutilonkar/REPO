    <div class="contact-item">
      <div class="contact-item-icon">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <div class="contact-item-label">Email</div>
      <div class="contact-item-value">hello@studionest.com</div>
    </div>
    <div class="contact-item">
      <div class="contact-item-icon">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.08 6.08l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
      </div>
      <div class="contact-item-label">Phone</div>
      <div class="contact-item-value">+91 (020) 123-4567</div>
    </div>
    <div class="contact-item">
      <div class="contact-item-icon">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <div class="contact-item-label">Studio</div>
      <div class="contact-item-value">Koregaon Park, Pune, MH 411001</div>
    </div>
  </div>
  <div style="margin-top:2.5rem;">
    <a href="/contact" class="btn btn-primary">Send Us a Message →</a>
  </div>
</section>
