<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-bg-image"></div>
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content">
    <div class="hero-eyebrow">
      <div class="hero-eyebrow-line"></div>
      <span class="hero-eyebrow-text">Architecture · BIM · Design Vision</span>
    </div>
    <h1 class="hero-title">Shaping spaces<br>that <em>inspire</em></h1>
    <p class="hero-desc">StudioNest Architects is a BIM-integrated architectural firm crafting buildings that merge precision, purpose, and poetic form.</p>
    <div class="hero-cta">
      <a href="/projects" class="btn btn-primary">View Our Work</a>
      <a href="/about" class="btn btn-outline">Our Approach</a>
    </div>
  </div>
</section>

<!-- SELECTED PROJECTS -->
<section class="section" style="padding-top:5rem;padding-bottom:0;">
  <div class="section-header fade-up">
    <div>
      <div class="label-accent">Portfolio</div>
      <h2 class="section-title">Selected Projects</h2>
    </div>
    <a href="/projects" class="btn btn-light btn-sm">All Projects →</a>
  </div>
</section>

<div class="projects-grid fade-up">
  <% if (projects && projects.length > 0) { %>
    <% projects.forEach(project => { %>
    <a href="/projects/<%= project._id %>" class="project-card">
      <img
        src="<%= project.imageUrl %>"
        alt="<%= project.title %>"
        class="project-card-image"
        loading="lazy"
        onerror="this.src='https://images.unsplash.com/photo-1486325212027-8081e485255e?w=800&q=80'"
      >
      <div class="project-card-body">
        <div class="project-card-meta">
          <span class="project-card-category"><%= project.category %></span>
          <span class="project-card-year"><%= project.year %></span>
        </div>
        <h3 class="project-card-title"><%= project.title %></h3>
        <p class="project-card-desc"><%= project.description %></p>
        <% if (project.bimEnabled) { %>
          <div class="bim-tag" style="margin-top:0.8rem;">⬡ BIM Coordinated</div>
        <% } %>
      </div>
    </a>
    <% }) %>
  <% } else { %>
    <div style="grid-column:1/-1;padding:4rem;text-align:center;color:var(--color-text-muted);">
      <p>No projects yet. <a href="/admin/projects/new" style="color:var(--color-accent);">Add your first project →</a></p>
    </div>
  <% } %>
</div>

<!-- ABOUT SECTION -->
<section class="section about-section">
  <div class="about-inner">
    <div class="fade-up">
      <div class="label" style="margin-bottom:0.8rem;">About Us</div>
      <h2 class="about-title">Design with<br><em>intention</em></h2>
      <div class="divider"></div>
    </div>
    <div class="fade-up">
      <p class="about-body">Founded in 2010, our studio brings together architects, engineers, and BIM specialists united by a belief that great architecture emerges from the dialogue between people, place, and purpose.</p>
      <p class="about-body">We work across scales — from intimate residences to large civic buildings — with a commitment to sustainability, material honesty, and spaces that elevate everyday life. Our BIM-first approach ensures precision from concept to construction.</p>
      <a href="/about" class="btn btn-dark" style="margin-bottom:2rem;">Learn More →</a>
      <div class="stats-row">
        <div class="stat-item">
          <div class="stat-number"><%= stats.projects %>+</div>
          <div class="stat-label">Projects Completed</div>
        </div>
        <div class="stat-item">
          <div class="stat-number"><%= stats.years %></div>
          <div class="stat-label">Years of Practice</div>
        </div>
        <div class="stat-item">
          <div class="stat-number"><%= stats.awards %></div>
          <div class="stat-label">Design Awards</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- BLOG SECTION -->
<% if (blogs && blogs.length > 0) { %>
<section class="section" style="background:#fff;">
  <div class="section-header fade-up">
    <div>
      <div class="label-accent">Insights</div>
      <h2 class="section-title">From the Studio</h2>
    </div>
    <a href="/blog" class="btn btn-light btn-sm">All Articles →</a>
  </div>
  <div class="blog-grid fade-up">
    <% blogs.forEach(blog => { %>
    <a href="/blog/<%= blog.slug %>" class="blog-card">
      <div class="blog-card-image-wrapper">
        <img
          src="<%= blog.imageUrl %>"
          alt="<%= blog.title %>"
          class="blog-card-image"
          loading="lazy"
          onerror="this.src='https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=800&q=80'"
        >
      </div>
      <div class="blog-card-body">
        <div class="blog-card-category"><%= blog.category %></div>
        <h3 class="blog-card-title"><%= blog.title %></h3>
        <p class="blog-card-excerpt"><%= blog.excerpt %></p>
        <div class="blog-card-footer">
          <span><%= blog.author %></span>
          <span><%= blog.readTime %> min read</span>
        </div>
      </div>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- CONTACT/CTA SECTION -->
