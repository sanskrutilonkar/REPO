<!-- PAGE HERO -->
<section class="page-hero" style="position:relative;overflow:hidden;min-height:50vh;display:flex;align-items:flex-end;">
  <div style="position:absolute;inset:0;">
    <img
      src="<%= project.imageUrl %>"
      alt="<%= project.title %>"
      style="width:100%;height:100%;object-fit:cover;opacity:0.4;"
      onerror="this.src='https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1600&q=80'"
    >
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,24,0.9) 40%,rgba(26,26,24,0.5));"></div>
  </div>
  <div style="position:relative;z-index:1;padding:calc(var(--nav-height) + 3rem) 8% 3rem;">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/projects">Projects</a>
      <span>/</span>
      <span><%= project.title %></span>
    </div>
    <div class="label-accent" style="margin-bottom:0.6rem;"><%= project.category %> · <%= project.year %></div>
    <h1 class="page-hero-title"><%= project.title %></h1>
  </div>
</section>

<!-- PROJECT INFO -->
<section class="content-section">
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:4rem;max-width:1100px;margin:0 auto;" class="project-detail-grid">

    <!-- MAIN CONTENT -->
    <div>
      <p style="font-size:1.15rem;color:var(--color-text-light);line-height:1.8;margin-bottom:1.5rem;"><%= project.description %></p>

      <% if (project.fullDescription) { %>
      <div class="article-content" style="max-width:none;">
        <%- project.fullDescription.replace(/\n/g, '<br>') %>
      </div>
      <% } %>

      <% if (project.tags && project.tags.length > 0) { %>
      <div style="margin-top:2rem;">
        <div class="label" style="margin-bottom:0.7rem;">Tags</div>
        <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
          <% project.tags.forEach(tag => { %>
            <span class="badge badge-accent" style="font-size:0.75rem;"><%= tag %></span>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- SIDEBAR -->
    <div>
      <div style="background:#fff;padding:1.8rem;border:1px solid var(--color-border);">
        <h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:400;margin-bottom:1.2rem;padding-bottom:0.8rem;border-bottom:1px solid var(--color-border);">Project Details</h3>

        <% if (project.client) { %>
        <div style="margin-bottom:1rem;">
          <div class="label" style="margin-bottom:0.2rem;">Client</div>
          <div style="font-size:0.9rem;"><%= project.client %></div>
        </div>
        <% } %>

        <% if (project.location) { %>
        <div style="margin-bottom:1rem;">
          <div class="label" style="margin-bottom:0.2rem;">Location</div>
          <div style="font-size:0.9rem;"><%= project.location %></div>
        </div>
        <% } %>

        <% if (project.area) { %>
        <div style="margin-bottom:1rem;">
          <div class="label" style="margin-bottom:0.2rem;">Area</div>
          <div style="font-size:0.9rem;"><%= project.area %></div>
        </div>
        <% } %>

        <div style="margin-bottom:1rem;">
          <div class="label" style="margin-bottom:0.2rem;">Year</div>
          <div style="font-size:0.9rem;"><%= project.year %></div>
        </div>

        <div style="margin-bottom:1rem;">
          <div class="label" style="margin-bottom:0.2rem;">Status</div>
          <% if (project.status === 'Completed') { %>
            <span class="badge badge-green"><%= project.status %></span>
          <% } else if (project.status === 'In Progress') { %>
            <span class="badge badge-orange"><%= project.status %></span>
          <% } else { %>
            <span class="badge badge-blue"><%= project.status %></span>
          <% } %>
        </div>

        <% if (project.bimEnabled) { %>
        <div style="margin-top:1.2rem;padding-top:1.2rem;border-top:1px solid var(--color-border);">
          <div class="bim-tag">⬡ BIM Coordinated Project</div>
          <p style="font-size:0.78rem;color:var(--color-text-muted);margin-top:0.5rem;">Full multi-disciplinary BIM coordination delivered for this project.</p>
        </div>
        <% } %>
      </div>

      <div style="margin-top:1.2rem;">
        <a href="/contact" class="btn btn-dark" style="width:100%;justify-content:center;">Discuss a Project →</a>
      </div>
    </div>
  </div>
</section>

<!-- RELATED PROJECTS -->
<% if (related && related.length > 0) { %>
<section class="related-section">
  <div class="label-accent" style="margin-bottom:0.5rem;">More Work</div>
  <h2 style="font-family:var(--font-display);font-size:2rem;font-weight:300;margin-bottom:2rem;">Related Projects</h2>
  <div class="related-grid">
    <% related.forEach(p => { %>
    <a href="/projects/<%= p._id %>" class="project-card">
      <img
        src="<%= p.imageUrl %>"
        alt="<%= p.title %>"
        class="project-card-image"
        loading="lazy"
        onerror="this.src='https://images.unsplash.com/photo-1486325212027-8081e485255e?w=800&q=80'"
      >
      <div class="project-card-body">
        <div class="project-card-meta">
          <span class="project-card-category"><%= p.category %></span>
          <span class="project-card-year"><%= p.year %></span>
        </div>
        <h3 class="project-card-title"><%= p.title %></h3>
      </div>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<style>
@media (max-width:768px) {
  .project-detail-grid { grid-template-columns: 1fr !important; }
}
</style>
